# Path to Google service account credentials JSON file
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Set to "true" to force mock data (mock mode also activates automatically if properties.json is missing)
MOCK_MODE=false

# Set to "true" to auto-discover all GA4 properties the service account has access to
# When enabled, properties.json is not needed — the app pulls properties from the GA4 Admin API
AUTO_DISCOVER=false
